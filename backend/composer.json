{
  "name": "college/neighborhood-safety-api",
  "description": "Laravel REST API for Neighborhood Safety and Incident Reporting System",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.2",
    "laravel/framework": "^11.0",
    "laravel/sanctum": "^4.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ]
  },
  "config": {
    "platform": {
      "php": "8.2.12"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
